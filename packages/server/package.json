{
  "name": "server",
  "version": "1.3.1",
  "description": "",
  "exports": "./server.js",
  "type": "module",
  "engines": {
    "node": ">=18.4"
  },
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun",
    "start": "NODE_ENV=production bun --max-old-space-size=256 server.js",
