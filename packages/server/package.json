    "@types/cache-manager": "^5.0.0",
    "@types/command-exists": "^1.2.1",
    "@types/cookie-parser": "^1.4.4",
    "@types/cors": "^2.8.14",
    "@types/express": "^5.0.6",
    "@types/express-fileupload": "^1.4.2",
    "@types/express-rate-limit": "^6.0.2",
    "@types/express-slow-down": "^2.0.0",
    "@types/fluent-ffmpeg": "^2.1.22",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.6",
    "@types/node": "^25.2.3",
    "@types/supertest": "^6.0.3",
    "@types/tmp": "^0.2.6",
    "@types/xo": "^0",
    "bun-types": "^1.3.9",
    "jest": "^30.2.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-jest-resolver": "^2.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "xo": "^1.2.3"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@keyv/sqlite": "^4.0.8",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cache-manager": "^7.2.8",
    "command-exists": "^1.2.9",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^8.2.1",
    "express-slow-down": "^3.0.1",
    "file-type": "^21.3.0",
    "fluent-ffmpeg": "^2.1.2",
    "ioredis": "^5.9.3",
    "keyv": "^5.6.0",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.6",
    "sanitize-filename": "^1.6.3",
    "sharp": "^0.34.5",
    "tmp": "^0.2.1",
    "winston": "^3.11.0"
  },
  "xo": {
    "space": true,
    "rules": {
      "new-cap": [
        "off"
      ],
      "unicorn/filename-case": [
        "error",
        {
          "case": "camelCase"
        }
      ]
    }
  }
