{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "personal-gallery",
  "version": "1.3.1",
  "description": "",
  "scripts": {
    "server-dev": "bun --filter server dev",
    "web-dev": "bun --filter web start",
    "start-dev": "run-p server-dev web-dev",
    "web-build": "bun --filter web build",
    "copy": "bun copyfiles -u 3 \"packages/web/build/*\" \"packages/web/build/**/*\" packages/server/public",
    "build": "bun web-build && bun --filter server build && bun copy",
    "build-dev": "NODE_ENV=development bun web-build && bun --filter server build && bun copy",
    "start": "bun --filter server start",
    "lint": "bun --filter server lint && bun --filter web lint"
  },
  "author": {
    "name": "Maksim Karasev"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "installConfig": {
    "hoistingLimits": "dependencies"
  },
  "overrides": {
    "@types/express": "^5.0.6"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "npm-run-all": "^4.1.5"
  },
  "xo": {
    "space": true,
    "rules": {
      "new-cap": [
        "off"
      ],
      "unicorn/filename-case": [
        "error",
        {
          "case": "camelCase"
        }
      ]
    }
  }
}
